; ==============================================================================
; Discord Rich Presence Configuration
; for more info refer to the README.md in the root of this file
; ==============================================================================
[rpc_settings]


; ============================= Primary Text Lines =============================
; These display as "Details" and "State" on your Discord profile

details = "Exploring the anomalies of {level}"

; when in the main menu, the addon will ignore party_size, party_limit, state, small_image_key, small_image_text and details
; and instead display only details_main_menu. Do not use any placeholders in this key as they do not exist in the main menu.
details_main_menu = "In the main menu"

state = "{money}₽ | {health}% HP"


; =================================== Assets ===================================

large_image_key = "https://raw.githubusercontent.com/gtair/Anomaly-RPC/refs/heads/main/assets/Anomaly_icon.webp"
large_image_text = "Playing Stalker Anomaly"

; if you are using my app ID in the cpp code, you can keep this as is to display faction patches.
small_image_key = "{faction_raw}"
small_image_text = "Member of {faction}"


; ============================ Party/Squad Details =============================
; Displays as "(party_size of party_max)" in Discord

party_size = {squad_size}

; if 0, party_max will be the same as party_size. recommended not to change
party_max = 0


; ========================== Clickable Custom Buttons ==========================
; Discord allows a maximum of 2 buttons. URLs must be full HTTPS links.

button_1_label = "Download Anomaly"
button_1_url = "https://www.moddb.com/mods/stalker-anomaly"

button_2_label = "Download Addon"
button_2_url = "https://github.com/gtair/Anomaly-RPC"